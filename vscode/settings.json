{
    // "workbench.tree.enableStickyScroll": false,
    // "editor.stickyScroll.scrollWithEditor": false,
    // "editor.hover.sticky": false,
    "editor.wordWrap": "on",
    "editor.mouseWheelZoom": true,
    "editor.stickyScroll.enabled": false,
    "editor.formatOnSave": false,
    "editor.suggest.insertMode": "replace",
    "editor.foldingStrategy": "indentation",
    "terminal.integrated.fontFamily": "MesloLGS NF",
    "editor.linkedEditing": true,
    "javascript.updateImportsOnFileMove.enabled": "always",
    "window.zoomLevel": 0.5,
    "launch": {},
    "[jsonc]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[html]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "editor.minimap.enabled": false,
    "workbench.iconTheme": "material-icon-theme", // Material Icon Theme
    "workbench.colorTheme": "GitHub Dark Default", // Github Theme
    "breadcrumbs.enabled": false,
    "workbench.activityBar.location": "hidden",
    "workbench.startupEditor": "none",
    "update.showReleaseNotes": false,
    "zenMode.hideLineNumbers": false,
    "editor.lineNumbers": "relative",
    "vim.leader": "<Space>",
    "vim.hlsearch": true,
    "vim.foldfix": true,
    "vim.insertModeKeyBindings": [
    ],
    "vim.commandLineModeKeyBindings": [
    ],
    "vim.normalModeKeyBindingsNonRecursive": [
        // NAVIGATION
        // switch b/w buffers
        { "before": ["leader", "h"], "commands": [":bprevious"] },
        { "before": ["leader", "l"], "commands": [":bnext"] },
        // splits
        { "before": ["leader", "v"], "commands": [":vsplit"] },
        { "before": ["leader", "s"], "commands": [":split"] },
        // NICE TO HAVE
        { "before": ["<Esc>", "<Esc>"], "commands": [":nohlsearch"] },
        { "before": ["leader", "o"], "after": ["o", "<Esc>"] },
        { "before": ["leader", "O"], "after": ["O", "<Esc>"] },
    ],
    "vim.visualModeKeyBindings": [
        { "before": ["leader", "p"], "after": ["\"", "_", "d", "P"]},
        { "before": ["leader", "c", "y"], "after": ["\"", "*", "y"] },
        { "before": ["leader", "c", "p"], "after": ["\"", "*", "p"] },
    ]
}
